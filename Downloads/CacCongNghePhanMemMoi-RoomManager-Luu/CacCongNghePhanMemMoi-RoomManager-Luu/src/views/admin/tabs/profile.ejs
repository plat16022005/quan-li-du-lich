<!-- Profile Tab -->
<div id="profileTab" style="display: none">
  <div class="profile-card">
    <div class="profile-header">
      <div class="avatar" id="adminAvatar">A</div>
      <div class="profile-info">
        <h2 id="adminName">Admin User</h2>
        <p id="adminEmail">admin@example.com</p>
        <span class="role-badge">ADMIN</span>
      </div>
    </div>

    <div class="profile-field">
      <label>Email</label>
      <p id="profileEmail">admin@example.com</p>
    </div>

    <div class="profile-field">
      <label>Tên</label>
      <p id="profileName">Admin User</p>
    </div>

    <div class="profile-field">
      <label>Số điện thoại</label>
      <p id="profilePhone">Chưa cập nhật</p>
    </div>

    <div class="profile-field">
      <label>Địa chỉ</label>
      <p id="profileAddress">Chưa cập nhật</p>
    </div>

    <div class="profile-field">
      <label>Quyền</label>
      <p>Quản trị viên hệ thống</p>
    </div>
  </div>
</div>
