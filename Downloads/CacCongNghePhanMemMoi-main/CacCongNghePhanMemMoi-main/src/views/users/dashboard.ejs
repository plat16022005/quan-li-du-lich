<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cổng thông tin Người thuê – Neet Paradise</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --navy: #0f172a;
            --navy-2: #1e293b;
            --primary: #2563eb;
            --primary-soft: #eef5ff;
            --teal: #0f766e;
            --teal-soft: #ecfeff;
            --green: #16a34a;
            --green-soft: #ecfdf3;
            --orange: #f59e0b;
            --orange-soft: #fff7ed;
            --red: #dc2626;
            --red-soft: #fef2f2;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e2e8f0;
            --surface: #ffffff;
            --surface-2: #f8fafc;
            --bg: #f1f5f9;
            --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            --radius: 18px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background:
                radial-gradient(circle at top, rgba(37, 99, 235, 0.06), transparent 18%),
                var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        nav {
            position: sticky;
            top: 0;
            z-index: 100;
            height: 74px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 6%;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo-box {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--teal));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: white;
        }

        .logo-text {
            font-size: 18px;
            font-weight: 800;
            color: var(--navy);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-greeting {
            font-weight: 600;
            color: var(--navy-2);
            font-size: 14px;
        }

        .btn-profile,
        .btn-logout {
            padding: 10px 16px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-profile {
            background: var(--surface-2);
            color: var(--navy-2);
            border: 1px solid var(--border);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-profile:hover {
            background: var(--primary-soft);
            color: var(--primary);
        }

        .btn-logout {
            background: var(--surface);
            color: var(--red);
            border: 1px solid rgba(220, 38, 38, 0.22);
        }

        .btn-logout:hover {
            background: var(--red);
            color: white;
        }

        .container {
            max-width: 1220px;
            margin: 32px auto 48px;
            padding: 0 6%;
        }

        .section-header {
            margin-bottom: 22px;
        }

        .section-header h2 {
            font-size: 30px;
            font-weight: 800;
            color: var(--navy);
            margin-bottom: 8px;
        }

        .section-header p {
            color: var(--muted);
            font-size: 15px;
        }

        .tenant-hero {
            background: linear-gradient(90deg, #eff6ff 0%, #f8fafc 100%);
            border-radius: var(--radius);
            padding: 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            border: 1px solid var(--border);
            margin-bottom: 22px;
        }

        .tenant-hero h3 {
            font-size: 22px;
            color: var(--navy);
            margin-bottom: 6px;
        }

        .tenant-hero p {
            color: var(--muted);
            font-size: 14px;
        }

        .tenant-hero-badge {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 10px 14px;
            color: var(--primary);
            font-weight: 700;
            font-size: 13px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 22px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px;
            box-shadow: var(--shadow);
        }

        .stat-card small {
            display: block;
            color: var(--muted);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .stat-card strong {
            font-size: 24px;
            color: var(--navy);
        }

        .room-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 22px;
            margin-bottom: 40px;
        }

        .application-section {
            margin-bottom: 22px;
        }

        .application-list {
            display: grid;
            gap: 14px;
        }

        .application-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 16px 18px;
            border: 1px solid var(--border);
            background: var(--surface-2);
            border-radius: 14px;
        }

        .application-item strong {
            display: block;
            color: var(--navy);
            font-size: 15px;
        }

        .application-meta {
            color: var(--muted);
            font-size: 13px;
        }

        .application-actions {
            display: flex;
            gap: 8px;
        }

        .btn-secondary {
            border: 1px solid var(--border);
            background: white;
            color: var(--navy-2);
            border-radius: 10px;
            padding: 10px 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-danger {
            border: 1px solid rgba(220, 38, 38, 0.2);
            background: white;
            color: var(--red);
            border-radius: 10px;
            padding: 10px 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-danger:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .room-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 22px;
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .room-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, var(--primary), var(--teal));
        }

        .room-card:hover {
            transform: translateY(-3px);
            border-color: #bfdbfe;
        }

        .room-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            font-size: 20px;
            font-weight: 800;
            color: var(--navy);
            margin-bottom: 10px;
        }

        .room-price {
            font-size: 22px;
            font-weight: 800;
            color: var(--teal);
            margin-bottom: 10px;
        }

        .room-meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 18px;
        }

        .room-actions {
            display: flex;
            gap: 10px;
        }

        .btn-rent {
            width: 100%;
            padding: 12px 14px;
            background: linear-gradient(90deg, var(--primary), #3b82f6);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-rent:hover {
            filter: brightness(1.03);
        }

        .btn-outline {
            background: white;
            color: var(--navy-2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .my-room-dashboard {
            display: grid;
            grid-template-columns: 1fr 1.6fr;
            gap: 24px;
        }

        .dashboard-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .dashboard-card h3,
        .card-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--navy);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px dashed var(--border);
        }

        .info-label {
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
        }

        .info-value {
            color: var(--navy);
            font-weight: 700;
            font-size: 14px;
            text-align: right;
            max-width: 60%;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 14px 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        th {
            background: var(--surface-2);
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        tbody tr:hover {
            background: #f8fafc;
        }

        .status-badge {
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
        }

        .status-paid {
            background: var(--green-soft);
            color: var(--green);
        }

        .status-unpaid {
            background: var(--red-soft);
            color: var(--red);
        }

        .loading,
        .empty-state {
            text-align: center;
            padding: 32px 18px;
            color: var(--muted);
            font-size: 14px;
        }

        .alert {
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 18px;
            font-weight: 600;
            display: none;
        }

        .alert-success {
            background: var(--green-soft);
            color: var(--green);
            border: 1px solid #a7f3d0;
        }

        .alert-error {
            background: var(--red-soft);
            color: var(--red);
            border: 1px solid #fecaca;
        }

        .modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(15, 23, 42, 0.48);
            padding: 24px;
            z-index: 2000;
        }

        .modal-panel {
            background: var(--surface);
            width: min(640px, 100%);
            border-radius: 22px;
            box-shadow: var(--shadow);
            padding: 24px;
            position: relative;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 18px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            width: 40px;
            height: 40px;
            border-radius: 999px;
            font-size: 22px;
            cursor: pointer;
            color: var(--muted);
        }

        .modal-panel h3 {
            font-size: 22px;
            color: var(--navy);
            margin-bottom: 18px;
        }

        .modal-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 18px;
        }

        .modal-grid .info-row {
            padding: 10px 0;
        }

        @media (max-width: 900px) {
            .my-room-dashboard {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            nav {
                padding: 0 18px;
            }

            .nav-right {
                gap: 6px;
            }

            .user-greeting {
                display: none;
            }

            .container {
                padding: 0 18px;
            }

            .tenant-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .modal-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo">
            <div class="logo-box">🏠</div>
            <span class="logo-text">Neet Paradise</span>
        </a>
        <div class="nav-right">
            <div class="user-greeting" id="userGreeting">Xin chào, <%= locals.user ? locals.user.name : 'Khách' %></div>
            <a href="/user/profile" class="btn-profile">👤 Hồ sơ</a>
            <button class="btn-logout" onclick="logout()">Đăng xuất</button>
        </div>
    </nav>

    <div class="container">
        <div id="alertMessage" class="alert"></div>

        <!-- VIEW: CHƯA CÓ PHÒNG (THUÊ PHÒNG) -->
        <div id="viewNoRoom" style="display: none;">
            <div class="section-header">
                <h2>👋 Chào mừng bạn đến với Neet Paradise</h2>
                <p>Có vẻ như bạn chưa thuê phòng nào. Dưới đây là danh sách căn hộ đang trống, hãy chọn một nơi phù hợp nhất.</p>
            </div>

            <div class="tenant-hero">
                <div>
                    <h3>Khám phá căn hộ phù hợp</h3>
                    <p>Tìm phòng sạch sẽ, tiện nghi và dễ dàng quản lý ngay từ điện thoại.</p>
                </div>
                <span class="tenant-hero-badge">Đang có phòng trống</span>
            </div>

            <div class="dashboard-card application-section">
                <div class="card-title">📄 Đơn thuê của tôi</div>
                <div class="application-list" id="applicationsList">
                    <div class="loading">Đang tải đơn thuê...</div>
                </div>
            </div>

            <div class="room-grid" id="availableRoomsGrid">
                <div class="loading">Đang tải danh sách phòng...</div>
            </div>
        </div>

        <!-- VIEW: ĐÃ CÓ PHÒNG (DASHBOARD) -->
        <div id="viewHasRoom" style="display: none;">
            <div class="section-header">
                <h2>🏠 Tổng quan căn hộ của bạn</h2>
                <p>Theo dõi thông tin phòng và lịch sử thanh toán của bạn một cách rõ ràng.</p>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <small>Số phòng</small>
                    <strong id="statRoomNumber">--</strong>
                </div>
                <div class="stat-card">
                    <small>Giá thuê</small>
                    <strong id="statRoomPrice">--</strong>
                </div>
                <div class="stat-card">
                    <small>Hóa đơn chờ</small>
                    <strong id="statPendingBills">--</strong>
                </div>
            </div>

            <div class="dashboard-card application-section">
                <div class="card-title">📄 Đơn thuê của tôi</div>
                <div class="application-list" id="applicationsList">
                    <div class="loading">Đang tải đơn thuê...</div>
                </div>
            </div>
            
            <div class="my-room-dashboard">
                <div class="dashboard-card">
                    <h3>✨ Thông tin căn hộ</h3>
                    <div class="info-row">
                        <span class="info-label">Số phòng</span>
                        <span class="info-value" id="myRoomNumber">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Tầng</span>
                        <span class="info-value" id="myRoomFloor">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Diện tích</span>
                        <span class="info-value" id="myRoomArea">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số phòng ngủ</span>
                        <span class="info-value" id="myRoomBedrooms">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số phòng tắm</span>
                        <span class="info-value" id="myRoomBathrooms">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số người tối đa</span>
                        <span class="info-value" id="myRoomMaxOccupants">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Giá thuê cơ bản</span>
                        <span class="info-value" id="myRoomPrice">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Tiền cọc</span>
                        <span class="info-value" id="myRoomDeposit">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Trạng thái</span>
                        <span class="info-value">Đang sử dụng</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Mô tả</span>
                        <span class="info-value" id="myRoomDescription">--</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Liên hệ quản lý</span>
                        <span class="info-value">manager@neetparadise.com</span>
                    </div>
                </div>

                <div class="dashboard-card" style="padding: 0; overflow: hidden;">
                    <div class="card-title" style="padding: 22px 22px 0;">🧾 Lịch sử hóa đơn</div>
                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>Kỳ thu</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Hạn nộp</th>
                                </tr>
                            </thead>
                            <tbody id="invoiceTableBody">
                                <tr>
                                    <td colspan="4" class="loading">Đang tải hóa đơn...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL XEM CHI TIẾT PHÒNG -->
        <div id="roomDetailModal" class="modal">
            <div class="modal-panel">
                <button onclick="closeRoomDetail()" class="modal-close">&times;</button>
                <h3>Chi tiết phòng <span id="modalRoomNumber"></span></h3>
                
                <div class="modal-grid">
                    <div class="info-row"><span class="info-label">Tầng</span><span class="info-value" id="modalFloor"></span></div>
                    <div class="info-row"><span class="info-label">Diện tích</span><span class="info-value" id="modalArea"></span></div>
                    <div class="info-row"><span class="info-label">Số phòng ngủ</span><span class="info-value" id="modalBedrooms"></span></div>
                    <div class="info-row"><span class="info-label">Số phòng tắm</span><span class="info-value" id="modalBathrooms"></span></div>
                    <div class="info-row"><span class="info-label">Số người tối đa</span><span class="info-value" id="modalMaxOccupants"></span></div>
                    <div class="info-row"><span class="info-label">Giá thuê</span><span class="info-value" id="modalPrice"></span></div>
                    <div class="info-row"><span class="info-label">Tiền cọc</span><span class="info-value" id="modalDeposit"></span></div>
                </div>
                
                <div style="margin-bottom: 18px;">
                    <strong style="color: var(--navy); display: block; margin-bottom: 8px;">Mô tả chi tiết</strong>
                    <p id="modalDescription" style="color: var(--muted); font-size: 14px; line-height: 1.6;"></p>
                </div>
                
                <button class="btn-rent" id="modalRentBtn">Thuê phòng này</button>
            </div>
        </div>

        <div id="applicationModal" class="modal">
            <div class="modal-panel" style="max-width: 980px; max-height: 90vh; overflow-y: auto;">
                <button onclick="closeApplicationModal()" class="modal-close">&times;</button>
                <h3 style="margin-bottom: 12px;">Chi tiết đơn thuê</h3>
                <div class="modal-grid">
                    <div class="info-row"><span class="info-label">Trạng thái</span><span class="info-value" id="appStatus"></span></div>
                    <div class="info-row"><span class="info-label">Ngày gửi</span><span class="info-value" id="appDate"></span></div>
                </div>

                <div style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 18px; margin-top: 12px;">
                    <div>
                        <strong style="color: var(--navy); display: block; margin-bottom: 8px;">Thông tin khách hàng</strong>
                        <div class="modal-grid">
                            <div class="info-row"><span class="info-label">Họ tên</span><span class="info-value" id="appUserName"></span></div>
                            <div class="info-row"><span class="info-label">SĐT</span><span class="info-value" id="appUserPhone"></span></div>
                            <div class="info-row"><span class="info-label">Ngày sinh</span><span class="info-value" id="appUserDob"></span></div>
                            <div class="info-row"><span class="info-label">Giới tính</span><span class="info-value" id="appUserGender"></span></div>
                            <div class="info-row" style="grid-column: 1 / -1;"><span class="info-label">Địa chỉ</span><span class="info-value" id="appUserAddress"></span></div>
                        </div>
                    </div>
                    <div>
                        <strong style="color: var(--navy); display: block; margin-bottom: 8px;">Thông tin phòng</strong>
                        <div class="modal-grid">
                            <div class="info-row"><span class="info-label">Phòng</span><span class="info-value" id="appRoomNumber"></span></div>
                            <div class="info-row"><span class="info-label">Giá thuê</span><span class="info-value" id="appRoomPrice"></span></div>
                            <div class="info-row" style="grid-column: 1 / -1;"><span class="info-label">Tầng / Diện tích</span><span class="info-value" id="appRoomInfo"></span></div>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 18px;">
                    <strong style="color: var(--navy); display: block; margin-bottom: 8px;">🪪 Ảnh CCCD</strong>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
                        <div style="border: 1px solid var(--border); border-radius: 12px; padding: 10px; background: var(--surface-2);">
                            <p style="font-size: 13px; color: var(--muted); margin-bottom: 8px;">Mặt trước</p>
                            <img id="appCccdFront" src="" alt="CCCD mặt trước" style="width: 100%; height: 220px; object-fit: cover; border-radius: 10px; background: #eef2ff;">
                        </div>
                        <div style="border: 1px solid var(--border); border-radius: 12px; padding: 10px; background: var(--surface-2);">
                            <p style="font-size: 13px; color: var(--muted); margin-bottom: 8px;">Mặt sau</p>
                            <img id="appCccdBack" src="" alt="CCCD mặt sau" style="width: 100%; height: 220px; object-fit: cover; border-radius: 10px; background: #eef2ff;">
                        </div>
                    </div>
                </div>

                <div style="margin-top: 18px;">
                    <strong style="color: var(--navy); display: block; margin-bottom: 8px;">👥 Người ở ghép</strong>
                    <div id="appMembersContainer"></div>
                </div>
            </div>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', initDashboard);

        function showAlert(message, type) {
            const alertEl = document.getElementById('alertMessage');
            alertEl.textContent = message;
            alertEl.className = `alert alert-${type}`;
            alertEl.style.display = 'block';
            setTimeout(() => {
                alertEl.style.display = 'none';
            }, 4000);
        }

        let currentApplications = [];

        async function initDashboard() {
            try {
                await loadMyApplications();
                const roomRes = await fetch("/api/rooms/my-room", { credentials: "include" });
                if (!roomRes.ok) throw new Error("Failed to fetch my room");
                const roomResult = await roomRes.json();
                const hasPendingApplication = currentApplications.some(app => app.status === 'pending');
                
                if (roomResult.data && roomResult.data.roomNumber) {
                    document.getElementById('viewNoRoom').style.display = 'none';
                    document.getElementById('viewHasRoom').style.display = 'block';
                    
                    document.getElementById('myRoomNumber').textContent = roomResult.data.roomNumber;
                    document.getElementById('myRoomFloor').textContent = roomResult.data.floor || '--';
                    document.getElementById('myRoomArea').textContent = (roomResult.data.area || '--') + ' m²';
                    document.getElementById('myRoomBedrooms').textContent = roomResult.data.bedroomCount || '--';
                    document.getElementById('myRoomBathrooms').textContent = roomResult.data.bathroomCount || '--';
                    document.getElementById('myRoomMaxOccupants').textContent = roomResult.data.maxOccupants || '--';
                    document.getElementById('myRoomPrice').textContent = Number(roomResult.data.rentalPrice).toLocaleString() + ' đ';
                    document.getElementById('myRoomDeposit').textContent = roomResult.data.depositAmount ? Number(roomResult.data.depositAmount).toLocaleString() + ' đ' : '--';
                    document.getElementById('myRoomDescription').textContent = roomResult.data.description || 'Không có mô tả';
                    document.getElementById('statRoomNumber').textContent = roomResult.data.roomNumber;
                    document.getElementById('statRoomPrice').textContent = Number(roomResult.data.rentalPrice).toLocaleString() + ' đ';
                    
                    loadInvoices();
                } else if (hasPendingApplication) {
                    document.getElementById('viewHasRoom').style.display = 'none';
                    document.getElementById('viewNoRoom').style.display = 'block';
                    renderPendingApplicationOverview();
                } else {
                    document.getElementById('viewHasRoom').style.display = 'none';
                    document.getElementById('viewNoRoom').style.display = 'block';
                    
                    loadAvailableRooms();
                }
            } catch (err) {
                console.error(err);
                showAlert("Đã có lỗi xảy ra khi tải dữ liệu.", "error");
            }
        }

        function renderPendingApplicationOverview() {
            const pendingApp = currentApplications.find(app => app.status === 'pending');
            const grid = document.getElementById('availableRoomsGrid');
            if (!pendingApp || !grid) return;

            const room = pendingApp.roomId || {};
            const tenant = pendingApp.tenantInfo || {};
            const memberCount = Array.isArray(pendingApp.members) ? pendingApp.members.length : 0;
            const roomId = room._id || room.id || pendingApp.roomId?._id || pendingApp.roomId;

            grid.innerHTML = `
                <div class="room-card" style="width: 100%; max-width: 100%;">
                    <div class="room-title">
                        Phòng ${room.roomNumber || '--'}
                        <span class="tenant-hero-badge">Đang chờ duyệt</span>
                    </div>
                    <div class="room-price">${room.rentalPrice ? Number(room.rentalPrice).toLocaleString() + ' đ/tháng' : '--'}</div>
                    <p class="room-meta">
                        ${room.area ? room.area + ' m²' : '-- m²'} • Tầng ${room.floor || '--'} • ${room.bedroomCount || '--'} PN
                    </p>
                    <p class="room-meta" style="margin-top: -10px;">
                        ${room.description || 'Đang chờ quản lý xét duyệt.'}
                    </p>
                    <div style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px; color: var(--muted); font-size: 14px;">
                        <div><strong>Người gửi:</strong> ${tenant.name || 'N/A'}</div>
                        <div><strong>SĐT:</strong> ${tenant.phoneNumber || 'N/A'}</div>
                        <div><strong>Ngày gửi:</strong> ${new Date(pendingApp.createdAt).toLocaleString('vi-VN')}</div>
                        <div><strong>Người ở ghép:</strong> ${memberCount}</div>
                    </div>
                    <div class="room-actions">
                        ${roomId ? `<button class="btn-outline" onclick="window.location.href='/dashboard/room/${roomId}'">Xem chi tiết phòng</button>` : ''}
                        <button class="btn-outline" onclick="viewApplication('${pendingApp._id}')">Xem chi tiết đơn</button>
                    </div>
                </div>
            `;
        }

        async function loadAvailableRooms() {
            try {
                const res = await fetch("/api/rooms/available", { credentials: "include" });
                const result = await res.json();
                const grid = document.getElementById('availableRoomsGrid');
                
                if (!result.data || result.data.length === 0) {
                    grid.innerHTML = '<div class="loading">Hiện tại không có phòng nào trống. Vui lòng quay lại sau!</div>';
                    return;
                }

                grid.innerHTML = result.data.map(room => `
                    <div class="room-card">
                        <div class="room-title">
                            Phòng ${room.roomNumber}
                            <span class="tenant-hero-badge">Trống</span>
                        </div>
                        <div class="room-price">${Number(room.rentalPrice).toLocaleString()} đ/tháng</div>
                        <p class="room-meta">
                            ${room.area ? room.area + ' m²' : '-- m²'} • Tầng ${room.floor || '--'} • ${room.bedroomCount || 1} PN
                        </p>
                        <p class="room-meta" style="margin-top: -10px;">
                            ${room.description || 'Phòng thoáng mát, an ninh tốt, tiện ích đầy đủ.'}
                        </p>
                        <div class="room-actions">
                            <button class="btn-outline" onclick="window.location.href='/dashboard/room/${room.id}'">Xem chi tiết</button>
                            <button class="btn-rent" onclick="window.location.href='/dashboard/room/${room.id}/rent'">Thuê ngay</button>
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                console.error(err);
                document.getElementById('availableRoomsGrid').innerHTML = '<div class="loading">Lỗi khi tải danh sách phòng.</div>';
            }
        }

        async function loadMyApplications() {
            try {
                const res = await fetch('/api/applications/my-applications', { credentials: 'include' });
                const result = await res.json();
                const list = document.getElementById('applicationsList');

                if (!res.ok) throw new Error(result.message || 'Không thể tải đơn thuê');

                currentApplications = result.data || [];

                if (!currentApplications.length) {
                    list.innerHTML = '<div class="empty-state">Bạn chưa gửi đơn thuê nào.</div>';
                    return;
                }

                list.innerHTML = currentApplications.map(app => {
                    const statusMap = {
                        pending: 'Đang chờ duyệt',
                        approved: 'Đã duyệt (chờ cọc)',
                        completed: 'Đã hoàn tất',
                        rejected: 'Đã từ chối'
                    };
                    const canManage = app.status === 'pending';
                    return `
                        <div class="application-item">
                            <div>
                                <strong>Phòng ${app.roomId?.roomNumber || '--'}</strong>
                                <div class="application-meta">${new Date(app.createdAt).toLocaleDateString('vi-VN')} • ${statusMap[app.status] || app.status}</div>
                            </div>
                            <div class="application-actions">
                                <button class="btn-secondary" onclick="viewApplication('${app._id}')">Xem</button>
                                ${canManage ? `<button class="btn-secondary" onclick="window.location.href='/dashboard/room/${app.roomId?._id || app.roomId}/rent'">Sửa</button>` : ''}
                                ${canManage ? `<button class="btn-danger" onclick="deleteApplication('${app._id}')">Xóa</button>` : ''}
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (err) {
                console.error(err);
                document.getElementById('applicationsList').innerHTML = '<div class="empty-state">Không thể tải đơn thuê.</div>';
            }
        }

        function viewApplication(appId) {
            const app = currentApplications.find(item => item._id === appId);
            if (!app) return;

            const tenant = app.tenantInfo || {};
            const room = app.roomId || {};
            const members = Array.isArray(app.members) ? app.members : [];
            const statusMap = {
                pending: 'Đang chờ duyệt',
                approved: 'Đã duyệt (chờ cọc)',
                completed: 'Đã hoàn tất',
                rejected: 'Đã từ chối'
            };

            const setText = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value || 'N/A';
            };
            const setImage = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.src = value || 'https://via.placeholder.com/400x220?text=Khong+co+anh';
            };

            setText('appStatus', statusMap[app.status] || app.status);
            setText('appDate', new Date(app.createdAt).toLocaleString('vi-VN'));
            setText('appUserName', tenant.name);
            setText('appUserPhone', tenant.phoneNumber);
            setText('appUserDob', tenant.dob);
            setText('appUserGender', tenant.gender === 'male' ? 'Nam' : tenant.gender === 'female' ? 'Nữ' : tenant.gender);
            setText('appUserAddress', tenant.address);
            setText('appRoomNumber', room.roomNumber);
            setText('appRoomPrice', room.rentalPrice ? Number(room.rentalPrice).toLocaleString() + ' đ' : 'N/A');
            setText('appRoomInfo', `Tầng ${room.floor || '?'} / ${room.area || '?'} m²`);
            setImage('appCccdFront', tenant.cccdFrontImage);
            setImage('appCccdBack', tenant.cccdBackImage);

            const membersContainer = document.getElementById('appMembersContainer');
            if (membersContainer) {
                if (members.length === 0) {
                    membersContainer.innerHTML = '<div class="empty-state">Không có thông tin người ở ghép</div>';
                } else {
                    membersContainer.innerHTML = members.map((member, index) => `
                        <div style="border: 1px solid var(--border); border-radius: 14px; padding: 14px; background: var(--surface-2); margin-bottom: 12px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 10px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <span style="display: inline-flex; width: 28px; height: 28px; align-items: center; justify-content: center; background: var(--primary-soft); color: var(--primary); border-radius: 999px; font-weight: 700; font-size: 13px;">${index + 1}</span>
                                    <strong style="color: var(--navy);">${member.name || 'N/A'}</strong>
                                </div>
                                <span class="tenant-hero-badge">Người ở ghép</span>
                            </div>
                            <div class="modal-grid">
                                <div class="info-row"><span class="info-label">SĐT</span><span class="info-value">${member.phoneNumber || 'N/A'}</span></div>
                                <div class="info-row"><span class="info-label">Ngày sinh</span><span class="info-value">${member.dob || 'N/A'}</span></div>
                                <div class="info-row"><span class="info-label">Giới tính</span><span class="info-value">${member.gender === 'male' ? 'Nam' : member.gender === 'female' ? 'Nữ' : (member.gender || 'N/A')}</span></div>
                                <div class="info-row" style="grid-column: 1 / -1;"><span class="info-label">Địa chỉ</span><span class="info-value">${member.address || 'N/A'}</span></div>
                            </div>
                            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 12px;">
                                <div style="border: 1px solid var(--border); border-radius: 10px; padding: 8px; background: white;">
                                    <p style="font-size: 12px; color: var(--muted); margin-bottom: 6px;">CCCD mặt trước</p>
                                    <img src="${member.cccdFrontImage || 'https://via.placeholder.com/400x220?text=Khong+co+anh'}" alt="CCCD mặt trước người ở ghép" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; background: #eef2ff;">
                                </div>
                                <div style="border: 1px solid var(--border); border-radius: 10px; padding: 8px; background: white;">
                                    <p style="font-size: 12px; color: var(--muted); margin-bottom: 6px;">CCCD mặt sau</p>
                                    <img src="${member.cccdBackImage || 'https://via.placeholder.com/400x220?text=Khong+co+anh'}" alt="CCCD mặt sau người ở ghép" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; background: #eef2ff;">
                                </div>
                            </div>
                        </div>
                    `).join('');
                }
            }

            document.getElementById('applicationModal').style.display = 'flex';
        }

        function closeApplicationModal() {
            document.getElementById('applicationModal').style.display = 'none';
        }

        async function deleteApplication(appId) {
            const app = currentApplications.find(item => item._id === appId);
            if (!app) return;
            if (['approved', 'completed'].includes(app.status)) {
                showAlert('Không thể xóa đơn đã được duyệt hoặc đã hoàn tất.', 'error');
                return;
            }
            if (!confirm('Bạn có chắc muốn xóa đơn thuê này không?')) return;

            try {
                const res = await fetch(`/api/applications/${appId}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });
                const data = await res.json();

                if (!res.ok) throw new Error(data.message || 'Xóa đơn thất bại');

                showAlert(data.message || 'Đã xóa đơn thuê.', 'success');
                loadMyApplications();
            } catch (err) {
                console.error(err);
                showAlert(err.message || 'Không thể xóa đơn thuê.', 'error');
            }
        }

        async function rentRoom(roomId, roomNumber) {
            if (!confirm(`Bạn có chắc chắn muốn thuê Phòng ${roomNumber} không?`)) return;

            try {
                const res = await fetch(`/api/rooms/${roomId}/rent`, {
                    method: "POST",
                    credentials: "include"
                });
                const data = await res.json();

                if (!res.ok) {
                    showAlert(data.message || "Thuê phòng thất bại!", "error");
                    return;
                }

                showAlert(`Thuê thành công Phòng ${roomNumber}!`, "success");
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } catch (err) {
                console.error(err);
                showAlert("Lỗi kết nối máy chủ.", "error");
            }
        }

        function viewRoomDetail(roomJson) {
            const room = JSON.parse(decodeURIComponent(roomJson));
            document.getElementById('modalRoomNumber').textContent = room.roomNumber;
            document.getElementById('modalFloor').textContent = room.floor || '--';
            document.getElementById('modalArea').textContent = room.area ? room.area + ' m²' : '--';
            document.getElementById('modalBedrooms').textContent = room.bedroomCount || '--';
            document.getElementById('modalBathrooms').textContent = room.bathroomCount || '--';
            document.getElementById('modalMaxOccupants').textContent = room.maxOccupants || '--';
            document.getElementById('modalPrice').textContent = Number(room.rentalPrice).toLocaleString() + ' đ/tháng';
            document.getElementById('modalDeposit').textContent = room.depositAmount ? Number(room.depositAmount).toLocaleString() + ' đ' : '--';
            document.getElementById('modalDescription').textContent = room.description || 'Chưa có mô tả.';
            
            document.getElementById('modalRentBtn').onclick = () => {
                closeRoomDetail();
                window.location.href = `/dashboard/room/${room.id}/rent`;
            };
            
            document.getElementById('roomDetailModal').style.display = 'flex';
        }

        function closeRoomDetail() {
            document.getElementById('roomDetailModal').style.display = 'none';
        }

        async function loadInvoices() {
            try {
                const res = await fetch("/api/rooms/my-invoices", { credentials: "include" });
                const result = await res.json();
                const tbody = document.getElementById('invoiceTableBody');
                const pendingCount = Array.isArray(result.data)
                    ? result.data.filter(inv => inv.status !== 'paid').length
                    : 0;

                document.getElementById('statPendingBills').textContent = pendingCount;

                if (!result.data || result.data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="loading">Chưa có hóa đơn nào được tạo.</td></tr>';
                    return;
                }

                tbody.innerHTML = result.data.map(inv => {
                    const isPaid = inv.status === 'paid';
                    const badgeClass = isPaid ? 'status-paid' : 'status-unpaid';
                    const badgeText = isPaid ? 'Đã thanh toán' : 'Chưa thanh toán';
                    
                    return `
                    <tr>
                        <td style="font-weight: 600; color: var(--navy);">${inv.month}</td>
                        <td style="font-weight: 700;">${Number(inv.totalBill).toLocaleString()} đ</td>
                        <td><span class="status-badge ${badgeClass}">${badgeText}</span></td>
                        <td style="color: var(--muted);">Mùng 5 hàng tháng</td>
                    </tr>
                `}).join('');
            } catch (err) {
                console.error(err);
                document.getElementById('invoiceTableBody').innerHTML = '<tr><td colspan="4" class="loading">Lỗi tải hóa đơn.</td></tr>';
            }
        }

        async function logout() {
            try {
                await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
                window.location.href = "/login";
            } catch (error) {
                console.error(error);
                alert("Lỗi kết nối!");
            }
        }
    </script>
</body>
</html>
