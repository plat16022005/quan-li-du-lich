<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Thông báo</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; background: #f8fafc; padding: 20px; color: #0f172a; }
    .container { max-width: 800px; margin: 0 auto; }
    .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .notif-item { padding: 16px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
    .notif-item.unread { background: #f0fdf4; border-left: 4px solid #10b981; }
    .notif-title { font-weight: bold; font-size: 16px; margin-bottom: 4px; }
    .notif-content { color: #475569; font-size: 14px; margin-bottom: 8px; }
    .notif-time { color: #94a3b8; font-size: 12px; }
    .btn-read { padding: 6px 12px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; }
    .btn-read-all { background: #f1f5f9; color: #3b82f6; padding: 10px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; width: 100%; margin-bottom: 20px; }
  </style>
</head>
<body>
  <div class="container">
    <button onclick="window.location.href='/dashboard'" style="padding:10px; margin-bottom:20px; border-radius:8px; border:1px solid #ccc; cursor:pointer;">← Quay lại</button>
    <div class="card">
      <h2 style="margin-bottom: 20px;">🔔 Hòm thư Thông báo</h2>
      <button class="btn-read-all" onclick="readAll()">Đánh dấu đã đọc tất cả</button>
      <div id="notifList"></div>
    </div>
  </div>

  <script>
    async function loadNotifs() {
      const res = await fetch("/api/resident/notifications");
      const json = await res.json();
      const list = document.getElementById("notifList");
      list.innerHTML = "";
      if(json.data.length === 0) {
        list.innerHTML = "<p style='text-align:center; color:#94a3b8;'>Không có thông báo nào.</p>";
        return;
      }
      json.data.forEach(n => {
        let btn = n.isRead ? '' : `<button class="btn-read" onclick="markRead('${n._id}')">Đánh dấu đã đọc</button>`;
        list.innerHTML += `
          <div class="notif-item ${n.isRead ? '' : 'unread'}">
            <div>
              <div class="notif-title">${n.title}</div>
              <div class="notif-content">${n.content}</div>
              <div class="notif-time">${new Date(n.createdAt).toLocaleString('vi-VN')}</div>
            </div>
            <div>${btn}</div>
          </div>
        `;
      });
    }

    async function markRead(id) {
      await fetch(`/api/resident/notifications/${id}/read`, { method: "PATCH" });
      loadNotifs();
    }

    async function readAll() {
      await fetch("/api/resident/notifications/read-all", { method: "PATCH" });
      loadNotifs();
    }

    window.onload = loadNotifs;
  </script>
</body>
</html>
