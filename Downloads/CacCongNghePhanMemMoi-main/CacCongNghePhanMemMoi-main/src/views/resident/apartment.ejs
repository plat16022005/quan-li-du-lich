<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thông tin Căn hộ</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; background: #f8fafc; padding: 20px; color: #0f172a; }
    .container { max-width: 800px; margin: 0 auto; }
    .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    h1 { color: #1e3a8a; margin-bottom: 20px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .label { font-weight: 600; color: #475569; font-size: 14px; text-transform: uppercase; }
    .val { font-size: 18px; margin-top: 5px; }
  </style>
</head>
<body>
  <div class="container">
    <button onclick="window.location.href='/dashboard'" style="padding:10px; margin-bottom:20px; border-radius:8px; border:1px solid #ccc; cursor:pointer;">← Quay lại</button>
    
    <div class="card" id="apartmentCard" style="display:none;">
      <h1>🏠 Căn hộ của bạn</h1>
      <div class="grid">
        <div><div class="label">Số phòng</div><div class="val" id="rNum" style="color:#1e3a8a; font-weight:bold;"></div></div>
        <div><div class="label">Tầng</div><div class="val" id="rFloor"></div></div>
        <div><div class="label">Diện tích</div><div class="val" id="rArea"></div></div>
        <div><div class="label">Phòng ngủ / Vệ sinh</div><div class="val" id="rBeds"></div></div>
        <div><div class="label">Giá thuê</div><div class="val" id="rPrice"></div></div>
        <div><div class="label">Trạng thái</div><div class="val" id="rStatus"></div></div>
      </div>
      <div style="margin-top:20px;">
        <button onclick="alert('Đang phát triển tính năng tải hợp đồng PDF!')" style="padding:10px 20px; background:#0f766e; color:white; border:none; border-radius:8px; cursor:pointer;">📄 Xem hợp đồng</button>
      </div>
    </div>
    
    <div class="card" id="noApartment" style="display:none; text-align:center; color:red;">
      <h2>Bạn chưa thuê căn hộ nào!</h2>
    </div>
  </div>

  <script>
    window.onload = async () => {
      try {
        const res = await fetch("/api/resident/apartment");
        if(res.ok) {
          const json = await res.json();
          const room = json.data;
          document.getElementById("apartmentCard").style.display = "block";
          document.getElementById("rNum").innerText = room.roomNumber;
          document.getElementById("rFloor").innerText = room.floor;
          document.getElementById("rArea").innerText = room.area + " m²";
          document.getElementById("rBeds").innerText = room.bedroomCount + " / " + room.bathroomCount;
          document.getElementById("rPrice").innerText = Number(room.rentalPrice).toLocaleString() + " VND";
          document.getElementById("rStatus").innerText = room.status;
        } else {
          document.getElementById("noApartment").style.display = "block";
        }
      } catch (e) {
        document.getElementById("noApartment").style.display = "block";
      }
    };
  </script>
</body>
</html>
