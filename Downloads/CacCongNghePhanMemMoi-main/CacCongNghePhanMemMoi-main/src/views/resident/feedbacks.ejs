<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Đánh giá Dịch vụ</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; background: #f8fafc; padding: 20px; color: #0f172a; }
    .container { max-width: 800px; margin: 0 auto; }
    .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 20px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: 500; }
    textarea { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; height: 100px; resize: none; }
    .stars { display: flex; gap: 5px; font-size: 30px; cursor: pointer; color: #cbd5e1; margin-bottom: 15px; }
    .stars span.active { color: #f59e0b; }
    .btn { padding: 10px 16px; border: none; border-radius: 6px; cursor: pointer; color: white; background: #1d4ed8; font-weight: bold; }
    .fb-item { padding: 15px; border-bottom: 1px solid #e2e8f0; }
    .fb-stars { color: #f59e0b; font-size: 18px; margin-bottom: 5px; }
    .fb-time { color: #94a3b8; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <button onclick="window.location.href='/dashboard'" style="padding:10px; margin-bottom:20px; border-radius:8px; border:1px solid #ccc; cursor:pointer;">← Quay lại</button>
    
    <div class="card">
      <h2>⭐ Đánh giá chất lượng dịch vụ</h2>
      <p style="color: #64748b; margin-bottom: 20px;">Ý kiến của bạn giúp chúng tôi cải thiện chất lượng tòa nhà tốt hơn.</p>
      <form id="fbForm">
        <div class="stars" id="starContainer">
          <span data-val="1">★</span><span data-val="2">★</span><span data-val="3">★</span><span data-val="4">★</span><span data-val="5">★</span>
        </div>
        <div class="form-group">
          <label>Nội dung góp ý</label>
          <textarea id="fbContent" required placeholder="Nhập nội dung..."></textarea>
        </div>
        <button type="submit" class="btn">Gửi đánh giá</button>
      </form>
    </div>

    <div class="card">
      <h2>Lịch sử đánh giá của bạn</h2>
      <div id="fbList"></div>
    </div>
  </div>

  <script>
    let currentRating = 0;
    const stars = document.querySelectorAll("#starContainer span");
    stars.forEach(s => {
      s.addEventListener("click", () => {
        currentRating = s.getAttribute("data-val");
        stars.forEach(st => st.classList.remove("active"));
        for(let i=0; i<currentRating; i++) stars[i].classList.add("active");
      });
    });

    async function loadFbs() {
      const res = await fetch("/api/resident/feedbacks");
      const json = await res.json();
      const list = document.getElementById("fbList");
      list.innerHTML = "";
      if(json.data.length === 0) { list.innerHTML = "<p>Chưa có đánh giá nào.</p>"; return; }
      
      json.data.forEach(fb => {
        let starHtml = '★'.repeat(fb.rating) + '☆'.repeat(5 - fb.rating);
        list.innerHTML += `
          <div class="fb-item">
            <div class="fb-stars">${starHtml}</div>
            <div>${fb.content}</div>
            <div class="fb-time">${new Date(fb.createdAt).toLocaleString('vi-VN')}</div>
          </div>
        `;
      });
    }

    document.getElementById("fbForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      if(currentRating === 0) return alert("Vui lòng chọn số sao!");
      const body = { rating: currentRating, content: document.getElementById("fbContent").value };
      const res = await fetch("/api/resident/feedbacks", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(body) });
      if(res.ok) { alert("Cảm ơn bạn đã đánh giá!"); document.getElementById("fbForm").reset(); currentRating=0; stars.forEach(st => st.classList.remove("active")); loadFbs(); }
    });

    window.onload = loadFbs;
  </script>
</body>
</html>
