@startuml
title Activity Diagram - Quy trình Đăng nhập

start

:Người dùng truy cập trang Đăng nhập;
repeat
    :Nhập Tên đăng nhập và Mật khẩu;
    :Bấm nút "Đăng nhập";
    
    :Hệ thống kiểm tra thông tin;
    if (Thông tin hợp lệ?) then (Đúng)
        :Hệ thống kiểm tra trạng thái tài khoản;
        if (Tài khoản bị khóa?) then (Có)
            :Hiển thị thông báo "Tài khoản bị khóa";
        else (Không)
            :Lấy thông tin Vai trò (Role);
            if (Vai trò là Quản lý?) then (Đúng)
                :Chuyển hướng đến Dashboard Quản lý;
            elseif (Vai trò là Nhân viên?) then (Đúng)
                :Chuyển hướng đến Dashboard Nhân viên;
            elseif (Vai trò là HDV/Tài xế?) then (Đúng)
                :Chuyển hướng đến Dashboard HDV/TX;
            else (Khách hàng)
                :Chuyển hướng đến Trang chủ Khách hàng;
            endif
            stop
        endif
    else (Sai)
        :Hiển thị thông báo "Sai tài khoản hoặc mật khẩu";
    endif
repeat while (Đăng nhập lại?) is (Yes)

stop
@enduml
